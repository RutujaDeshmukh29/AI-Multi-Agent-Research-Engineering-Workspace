# ========================
# AI Multi-Agent Workspace
# Root .gitignore
# ========================

# Environment files - NEVER commit these
.env
.env.local
.env.production
.env.development
*.env
.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# Node / Next.js
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Docker
*.log

# ChromaDB (local only - we use pgvector instead)
chroma_db/
chromadb/

# Uploads / temp files
uploads/
tmp/
temp/
