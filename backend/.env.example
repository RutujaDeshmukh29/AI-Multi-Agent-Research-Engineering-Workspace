# ========================
# Backend Environment Variables
# Copy this to .env and fill values
# NEVER commit .env to git
# ========================

# --- Application ---
APP_NAME="AI Multi-Agent Workspace"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development

# --- Server ---
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# --- Database (Supabase / Neon PostgreSQL) ---
# Get from: https://supabase.com or https://neon.tech
# Async URL (FastAPI / SQLAlchemy Async)

DATABASE_URL=postgresql+asyncpg://postgres:Rutuja_2829@db.ryryortlfjlqjztkswir.supabase.co:5432/postgres?ssl=require

# Sync URL (Alembic migrations)

DATABASE_URL_SYNC=postgresql://postgres:Rutuja_2829@db.ryryortlfjlqjztkswir.supabase.co:5432/postgres?sslmode=require

# --- JWT Authentication ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=57dadd76f0d33f3ef06876803ea9b9d1fb4f9ec509fa1b0dc85eb59fdf308c94
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Groq API ---
# Get from: https://console.groq.com
GROQ_API_KEY=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
GROQ_MODEL=llama-3.1-8b-instant
