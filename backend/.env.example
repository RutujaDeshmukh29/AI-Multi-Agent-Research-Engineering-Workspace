# ========================
# Backend Environment Variables
# Copy this to .env and fill values
# NEVER commit .env to git
# ========================

# --- Application ---
APP_NAME="AI Multi-Agent Workspace"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development

# --- Server ---
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# --- Database (Supabase / Neon PostgreSQL) ---
# Get from: https://supabase.com or https://neon.tech
DATABASE_URL=postgresql+asyncpg://postgres:Rutuja@2829@db.ryryortlfjlqjztkswir.supabase.co:5432/postgres

DATABASE_URL_SYNC=postgresql://postgres:Rutuja@2829@db.ryryortlfjlqjztkswir.supabase.co:5432/postgres


# --- JWT Authentication ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=57dadd76f0d33f3ef06876803ea9b9d1fb4f9ec509fa1b0dc85eb59fdf308c94
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Groq API ---
# Get from: https://console.groq.com
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile
